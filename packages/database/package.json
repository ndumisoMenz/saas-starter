{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "generate": "prisma generate --schema ./prisma/schema.prisma",
    "build": "npm run generate && tsc && cp -r ./generated ./dist/generated",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "pg": "^8.18.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "prisma": "^7.6.0",
    "typescript": "latest"
  }
}